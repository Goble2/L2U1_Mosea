# ═══════════════════════════════════════════════════════════════
#  .gitignore
#  Fichiers et dossiers ignorés par Git.
#  Ces éléments ne seront jamais envoyés sur GitHub.
# ═══════════════════════════════════════════════════════════════

# ── Variables d'environnement (contiennent les clés secrètes) ─
.env
.env.local
.env.*.local

# ── Dépendances npm ───────────────────────────────────────────
# Trop lourd à versionner — se réinstalle avec : npm install
node_modules/

# ── Build Vite / output de production ─────────────────────────
dist/
build/

# ── Fichiers système macOS ────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Fichiers système Windows ──────────────────────────────────
Thumbs.db
Desktop.ini

# ── Éditeurs de code ──────────────────────────────────────────
# VS Code
.vscode/
# JetBrains (WebStorm, etc.)
.idea/
# Vim
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Divers ────────────────────────────────────────────────────
*.local
.cache/
