# ═══════════════════════════════════════════════════════════════
#  .env.example
#  Modèle de configuration — CE fichier est commité sur GitHub.
#  Il montre quelles variables sont nécessaires, sans les vraies
#  valeurs. Chaque développeur copie ce fichier en .env et
#  renseigne ses propres clés.
#
#  Utilisation :
#    cp .env.example .env
#    # puis remplir les valeurs dans .env
# ═══════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
